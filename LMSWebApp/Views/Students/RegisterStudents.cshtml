@model DataAccessLayer.Models.Students

@{
    ViewData["Title"] = "RegisterStudents";
   
}

<h4>Register Students</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="RegisterStudents">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <div class="form-group">
                <label asp-for="RollNo" class="control-label"></label>
                <input asp-for="RollNo" class="form-control" />
                <span asp-validation-for="RollNo" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="FullName" class="control-label"></label>
                <input asp-for="FullName" class="form-control" />
                <span asp-validation-for="FullName" class="text-danger"></span>
            </div>
            <div class="form-group">
                <label asp-for="Department" class="control-label"></label>
              
                <select class="form-control" asp-for="Department">
                    <option value="">-- Select Dept --</option>
                    <option value="CSE">CSE</option>
                    <option value="IT">IT</option>
                    <option value="Mech">Mech</option>
                    <option value="Civil">Civil</option>
                </select>
                <span asp-validation-for="Department" class="text-danger"></span>
            </div>
            <br />
            <div class="form-group">
                <input type="submit" value="Create" class="btn btn-primary" />
            </div>
            <div class="form-group">
                @TempData["SuccessMessage"]
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="login" >Already u have Account!</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
